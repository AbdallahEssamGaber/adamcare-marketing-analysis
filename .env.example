# Gate password (server-only, sent over POST /api/login)
SECRET_KEY=your-shared-secret-key

# HMAC secret for signed session cookies. Falls back to SECRET_KEY if unset.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI (GPT-4o insights)
OPENAI_API_KEY=your-openai-key

# Instagram Graph API (via Meta)
META_APP_ID=your-meta-app-id
META_APP_SECRET=your-meta-app-secret
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-account-id
# Initial seed token; refreshed token is persisted to Supabase `settings` table.
INSTAGRAM_ACCESS_TOKEN=your-instagram-token

# TikTok Open API
TIKTOK_ACCESS_TOKEN=your-tiktok-token
